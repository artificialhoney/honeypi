{
  "name": "app-name",
  "version": "1.2.0",
  "main": "src/index.js",
  "license": "MIT",
  "scripts": {
    "start:dev": "yarn pm2:watch && yarn pm2:logs",
    "start:prod": "yarn pm2:production && yarn pm2:logs",
    "pm2:watch": "pm2 start --watch",
    "pm2:production": "pm2 start --env production",
    "pm2:prune": "pm2 delete app-name",
    "pm2:stop": "pm2 stop app-name",
    "pm2:logs": "pm2 logs -n app-name --raw",
    "pm2:flush": "pm2 flush"
  },
  "dependencies": {
    "pm2": "^3.5.1"
  }
}
