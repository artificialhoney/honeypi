LD_SUPERUSER_NAME=${HONEYPI_LINKDING_SUPERUSER_NAME:-honeypi}
LD_SUPERUSER_PASSWORD=${HONEYPI_LINKDING_SUPERUSER_PASSWORD}
LD_DISABLE_BACKGROUND_TASKS=${HONEYPI_LINKDING_DISABLE_BACKGROUND_TASKS:-True}
LD_DISABLE_URL_VALIDATION=False
LD_ENABLE_OIDC=${HONEYPI_LINKDING_ENABLE_OIDC:-False}
OIDC_OP_AUTHORIZATION_ENDPOINT=${HONEYPI_LINKDING_OIDC_OP_AUTHORIZATION_ENDPOINT}
OIDC_OP_TOKEN_ENDPOINT=${HONEYPI_LINKDING_OIDC_OP_TOKEN_ENDPOINT}
OIDC_OP_USER_ENDPOINT=${HONEYPI_LINKDING_OIDC_OP_USER_ENDPOINT}
OIDC_OP_JWKS_ENDPOINT=${HONEYPI_LINKDING_OIDC_OP_JWKS_ENDPOINT}
OIDC_RP_CLIENT_ID=${HONEYPI_LINKDING_OIDC_RP_CLIENT_ID}
OIDC_RP_CLIENT_SECRET=${HONEYPI_LINKDING_OIDC_RP_CLIENT_SECRET}
LD_DB_ENGINE=postgres
LD_DB_DATABASE=${HONEYPI_LINKDING_DB_DNAME:-linkding}
LD_DB_USER=${HONEYPI_POSTGRES_USER:-honeypi}
LD_DB_PASSWORD=${HONEYPI_POSTGRES_PASSWORD}
LD_DB_HOST=${HONEYPI_POSTGRES_HOST:-drone}
