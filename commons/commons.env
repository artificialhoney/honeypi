# Global
TZ=${HONEYPI_TZ:-'Europe/Amsterdam'}
LOG_LEVEL=${HONEYPI_LOG_LEVEL:-info}
ALLOW_EMPTY_PASSWORD=${HONEYPI_ALLOW_EMPTY_PASSWORD:-yes}
# mariadb
MARIADB_AUTO_UPGRADE=${HONEYPI_MARIADB_AUTO_UPGRADE:-1}
MARIADB_INITDB_SKIP_TZINFO=${HONEYPI_MARIADB_INITDB_SKIP_TZINFO:-1}
MARIADB_USER=${HONEYPI_MARIADB_USER:-honeypi}
MARIADB_PASSWORD=${HONEYPI_MARIADB_PASSWORD}
MARIADB_RANDOM_ROOT_PASSWORD=${HONEYPI_MARIADB_RANDOM_ROOT_PASSWORD:-1}
MARIADB_DISABLE_UPGRADE_BACKUP=${HONEYPI_MARIADB_DISABLE_UPGRADE_BACKUP:-1}
# postgres
POSTGRES_USER=${HONEYPI_POSTGRES_USER:-honeypi}
POSTGRES_PASSWORD=${HONEYPI_POSTGRES_PASSWORD}
PGDATA=${HONEYPI_POSTGRES_PGDATA:-/var/lib/postgresql/data/pgdata}
# gitlab
GITLAB_HOST=${HONEYPI_GITLAB_HOST:-gitlab}
GITLAB_ROOT_PASSWORD=${HONEYPI_GITLAB_PASSWORD}
DB_ADAPTER=${HONEYPI_GITLAB_DB_ADAPTER:-postgresql}
DB_HOST=${HONEYPI_POSTGRES_HOST:-postgres}
DB_USER=${HONEYPI_POSTGRES_USER:-honeypi}
DB_PASS=${HONEYPI_POSTGRES_PASSWORD}
DB_NAME=${HONEYPI_GITLAB_DB_NAME:-gitlab}
# nginxproxymanager
DB_MYSQL_HOST=${HONEYPI_MARIADB_HOST:-mariadb}
DB_MYSQL_USER=${HONEYPI_MARIADB_USER:-honeypi}
DB_MYSQL_PASSWORD=${HONEYPI_MARIADB_PASSWORD}
DB_MYSQL_NAME=${HONEYPI_NGINXPROXYMANAGER_DB_NAME:-nginxproxymanager}
# homeassistant
MYSQL_HA_DATABASE=${HONEYPI_HOMEASSISTANT_DB_NAME:-homeassistant}
MYSQL_HA_USER=${HONEYPI_MARIADB_USER:-honeypi}
MYSQL_HA_PASSWORD=${HONEYPI_MARIADB_PASSWORD}
# redis
REDIS_HOST=${HONEYPI_REDIS_HOST:-redis}
REDIS_PORT=${HONEYPI_REDIS_PORT:-6379}
# rocketchat
ROOT_URL=${HONEYPI_ROCKETCHAT_ROOT_URL}
MONGO_URL=${HONEYPI_ROCKETCHAT_DB_URL:-mongodb://mongo:27017/rocketchat}
MONGO_OPLOG_URL=${HONEYPI_ROCKETCHAT_DB_OPLOG_URL:-mongodb://mongo:27017/local}
# authentik
AUTHENTIK_REDIS__HOST=${HONEYPI_REDIS_HOST:-redis}
AUTHENTIK_POSTGRESQL__HOST=${HONEYPI_POSTGRES_HOST:-postgres}
AUTHENTIK_POSTGRESQL__USER=${HONEYPI_POSTGRES_USER:-honeypi}
AUTHENTIK_POSTGRESQL__NAME=${HONEYPI_AUTHENTIK_DB_NAME:-authentik}
AUTHENTIK_POSTGRESQL__PASSWORD=${HONEYPI_POSTGRES_PASSWORD}
AUTHENTIK_SECRET_KEY=${HONEYPI_AUTHENTIK_SECRET_KEY}
AUTHENTIK_EMAIL__HOST=${HONEYPI_EMAIL_HOST}
AUTHENTIK_EMAIL__PORT=${HONEYPI_EMAIL_PORT}
AUTHENTIK_EMAIL__USERNAME=${HONEYPI_EMAIL_USERNAME}
AUTHENTIK_EMAIL__PASSWORD=${HONEYPI_EMAIL_PASSWORD}
AUTHENTIK_EMAIL__FROM=${HONEYPI_EMAIL_FROM}
# photoprism
PHOTOPRISM_ADMIN_USER=${HONEYPI_PHOTOPRISM_ADMIN_USER:-honeypi}
PHOTOPRISM_ADMIN_PASSWORD=${HONEYPI_PHOTOPRISM_PASSWORD}
PHOTOPRISM_AUTH_MODE=${HONEYPI_PHOTOPRISM_AUTH_MODE:-password}
PHOTOPRISM_DETECT_NSFW=${HONEYPI_PHOTOPRISM_DETECT_NSFW:-false}
PHOTOPRISM_UPLOAD_NSFW=${HONEYPI_PHOTOPRISM_UPLOAD_NSFW:-true}
PHOTOPRISM_DATABASE_DRIVER=${HONEYPI_PHOTOPRISM_DB_DRIVER:-mysql}
PHOTOPRISM_DATABASE_SERVER=${HONEYPI_MARIADB_HOST:-mariadb}
PHOTOPRISM_DATABASE_NAME=${HONEYPI_PHOTOPRISM_DB_NAME:-photoprism}
PHOTOPRISM_DATABASE_USER=${HONEYPI_MARIADB_USER:-honeypi}
PHOTOPRISM_DATABASE_PASSWORD=${HONEYPI_MARIADB_PASSWORD}
PHOTOPRISM_OIDC_URI=${HONEYPI_PHOTOPRISM_OIDC_URI}
PHOTOPRISM_OIDC_CLIENT=${HONEYPI_PHOTOPRISM_OIDC_CLIENT}
PHOTOPRISM_OIDC_SECRET=${HONEYPI_PHOTOPRISM_OIDC_SECRET}
PHOTOPRISM_OIDC_PROVIDER=${HONEYPI_PHOTOPRISM_OIDC_PROVIDER}
PHOTOPRISM_OIDC_REDIRECT=${HONEYPI_PHOTOPRISM_OIDC_REDIRECT}
PHOTOPRISM_OIDC_REGISTER=${HONEYPI_PHOTOPRISM_OIDC_REGISTER}
PHOTOPRISM_OIDC_WEBDAV=${HONEYPI_PHOTOPRISM_OIDC_WEBDAV}
PHOTOPRISM_APP_NAME=${HONEYPI_PHOTOPRISM_APP_NAME}
PHOTOPRISM_APP_MODE=${HONEYPI_PHOTOPRISM_APP_MODE}
PHOTOPRISM_APP_ICON=${HONEYPI_PHOTOPRISM_APP_ICON}
PHOTOPRISM_APP_COLOR=${HONEYPI_PHOTOPRISM_APP_COLOR}
PHOTOPRISM_LEGAL_INFO=${HONEYPI_PHOTOPRISM_LEGAL_INFO}
PHOTOPRISM_LEGAL_URL=${HONEYPI_PHOTOPRISM_LEGAL_URL}
PHOTOPRISM_WALLPAPER_URI=${HONEYPI_PHOTOPRISM_WALLPAPER_URI}
PHOTOPRISM_CORS_ORIGIN=${HONEYPI_PHOTOPRISM_CORS_ORIGIN}
PHOTOPRISM_SITE_URL=${HONEYPI_PHOTOPRISM_SITE_URL}
PHOTOPRISM_ORIGINALS_LIMIT=${HONEYPI_PHOTOPRISM_ORIGINALS_LIMIT:-5000}
# jellyfin
JELLYFIN_PublishedServerUrl=${HONEYPI_JELLYFIN_SERVER_URL}
# webdav
AUTH_TYPE=${HONEYPI_WEBDAV_AUTH_TYPE:-Digest}
USERNAME=${HONEYPI_WEBDAV_USERNAME:-honeypi}
PASSWORD=${HONEYPI_WEBDAV_PASSWORD:-""}
# rpiplay
AIRPIPLAY_NAME=${HONEYPI_AIRPIPLAY_NAME:-honeypi}
AIRPIPLAY_AUDIO_OUT=${HONEYPI_AIRPIPLAY_AUDIO_OUT:-hdmi}
AIRPIPLAY_BACKGROUND=${HONEYPI_AIRPIPLAY_LATENCY_MODE:-auto}
AIRPIPLAY_ROTATION=${HONEYPI_AIRPIPLAY_ROTATION:-""}
AIRPIPLAY_FLIP=${HONEYPI_AIRPIPLAY_FLIP:-""}
# xibo
MYSQL_PASSWORD=${HONEYPI_MARIADB_PASSWORD}
MYSQL_USER=${HONEYPI_MARIADB_USER:-honeypi}
CMS_SMTP_SERVER=${HONEYPI_EMAIL_HOST}:${HONEYPI_EMAIL_PORT}
CMS_SMTP_USERNAME=${HONEYPI_EMAIL_USERNAME}
CMS_SMTP_PASSWORD=${HONEYPI_EMAIL_PASSWORD}
CMS_SMTP_USE_TLS=${HONEYPI_EMAIL_USE_TLS:-YES}
CMS_SMTP_USE_STARTTLS=${HONEYPI_EMAIL_USE_STARTTLS:-YES}
CMS_SMTP_FROM=${HONEYPI_EMAIL_FROM}
#n8n
N8N_HOST=${HONEYPI_N8N_HOST}
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=production
WEBHOOK_URL=https://${HONEYPI_N8N_HOST}
# dbgate
CONNECTIONS=con1,con2,con3
LABEL_con1=MariaDB
SERVER_con1=${HONEYPI_MARIADB_HOST:-mariadb}
USER_con1=${HONEYPI_MARIADB_USER:-honeypi}
PASSWORD_con1=${HONEYPI_MARIADB_PASSWORD}
ENGINE_con1=mysql@dbgate-plugin-mysql
LABEL_con2=Postgres
SERVER_con2=${HONEYPI_POSTGRES_HOST:-postgres}
USER_con2=${HONEYPI_POSTGRES_USER:-honeypi}
PASSWORD_con2=${HONEYPI_POSTGRES_PASSWORD}
ENGINE_con2=postgres@dbgate-plugin-postgres
LABEL_con3=MongoDB
URL_con3=mongodb://mongo:27017
ENGINE_con3=mongo@dbgate-plugin-mongo