#!/bin/bash

POSITIONAL_ARGS=()

HONEYPI_SCOPE=apps
HOST_MODULES=$(ls host | xargs -n 1 basename -s .sh)
APP_MODULES=$(ls apps | xargs -n 1 basename)
STACK_MODULES=$(ls stacks | xargs -n 1 basename)

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)
      echo 'honeypi'
      echo
      echo 'Usage:'
      echo '  honeypi run -e <env> -s <apps|host|stacks> <name>'
      echo '  honeypi remove <name>'
      echo '  honeypi sync -e <env>'
      echo '  honeypi -h | --help'
      echo 'Options:'
      echo '  -h --help                  Show this screen.'
      echo '  -e --environment=<env>     Environment [default: local].'
      echo '  -s --scope=<scope>         Scope [default: apps].'
      shift # past argument
      exit 0
      ;;
    -e|--environment)
      HONEYPI_ENVIRONMENT="$2"
      shift # past argument
      shift # past value
      ;;
    -s|--scope)
      HONEYPI_SCOPE="$2"
      shift # past argument
      shift # past value
      ;;
    -*|--*)
      echo "Unknown option $1"
      exit 1
      ;;
    *)
      POSITIONAL_ARGS+=("$1") # save positional arg
      shift # past argument
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

HONEYPI_ENVIRONMENT=${HONEYPI_ENVIRONMENT:-local}
echo "Loading environment from '${HONEYPI_ENVIRONMENT}.env'"
[ -f ${HONEYPI_ENVIRONMENT}.env ] && eval export $(cat ${HONEYPI_ENVIRONMENT}.env)

if [ "$1" = "sync" ]; then
  echo "Syncing with 'pi@${HONEYPI_HOST}'"
  rsync . -chavzP --stats pi@$HONEYPI_HOST:/home/pi/honeypi
  exit 0
elif [ "$1" = "connect" ]; then
  shift
  echo "Connecting to '$1'"
  docker exec -it $1 /bin/bash
  exit 0
elif [ "$1" = "run" ]; then
  shift
  sudo find ./apps -maxdepth 1 -execdir sh -c 'mkdir -p "${HONEYPI_HOME}/${0%}"' {} \;
  echo "Running in '${HONEYPI_SCOPE}' with '${@}'"
  if [ "$HONEYPI_SCOPE" = "host" ]; then
    for arg in "${@:-$HOST_MODULES}"
    do
      . "./host/$arg.sh"
    done
  elif [ "$HONEYPI_SCOPE" = "apps" ]; then
    for arg in "${@:-$APP_MODULES}"
    do
      docker-compose -f "./apps/$arg/docker-compose.yml" up -d
    done
  elif [ "$HONEYPI_SCOPE" = "stacks" ]; then
    for arg in "${@:-$STACK_MODULES}"
    do
      docker-compose -f "./stacks/$arg/docker-compose.yml" up -d
    done
  else
    echo "Unknown scope '$1'."
  fi
  exit 0
elif [ "$1" = "remove" ]; then
  shift
  docker stop "${@}"
  docker rm -v "${@}"
else
  echo "No argument(s) provided. Run -h for help."
  exit 0
fi

