#!/bin/bash

POSITIONAL_ARGS=()

HONEYPI_SCOPE=apps
HOST_MODULES=$(ls host | xargs -n 1 basename -s .sh)
APP_MODULES=$(ls apps | xargs -n 1 basename)

loadEnv() {
  source $1
}

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)
      echo 'honeypi'
      echo
      echo 'Usage:'
      echo '  honeypi run <name>'
      echo '  honeypi remove <name>'
      echo '  honeypi sync <from> <to>'
      echo '  honeypi env <env>'
      echo '  honeypi connect <name>'
      echo '  honeypi -h | --help'
      echo 'Options:'
      echo '  -h --help                  Show this screen.'
      echo '  -e --environment=<env>     Environment [default: local].'
      echo '  -n --native                Scope native [default: apps].'
      shift # past argument
      exit 0
      ;;
    -e|--environment)
      HONEYPI_ENVIRONMENT="$2"
      shift # past argument
      shift # past value
      ;;
    -n|--native)
      HONEYPI_SCOPE="host"
      shift # past argument
      ;;
    -*|--*)
      echo "Unknown option $1"
      exit 1
      ;;
    *)
      POSITIONAL_ARGS+=("$1") # save positional arg
      shift # past argument
      ;;
  esac
done

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

if [ "$1" = "env" ]; then
  shift
  echo "Loading environment from '${HONEYPI_ENVIRONMENT}'.env"
  [ -f "$HONEYPI_ENVIRONMENT.env" ] && loadEnv "$HONEYPI_ENVIRONMENT.env"
  set | grep HONEYPI_
  exit 0
elif [ "$1" = "sync" ]; then
  shift
  [ -f "$HONEYPI_ENVIRONMENT.env" ] && loadEnv "$HONEYPI_ENVIRONMENT.env"
  [[ ! "$1" = "" ]] && URL=$1 || URL=${HONEYPI_HOST_URL:-local}
  DIR="$(dirname "$(readlink -f "$0")")"
  DIR=${2:-"$DIR"}
  echo "Syncing to '${URL}' from '${DIR}'"
  rsync -chavzP --stats -e "ssh -A" $DIR/* $URL/
  exit 0
elif [ "$1" = "connect" ]; then
  shift
  [ -f $HONEYPI_ENVIRONMENT.env ] && loadEnv $HONEYPI_ENVIRONMENT.env
  echo "Connecting to '$1'"
  docker exec -it $1 /bin/bash
  exit 0
elif [ "$1" = "run" ]; then
  shift
  [ -f $HONEYPI_ENVIRONMENT.env ] && loadEnv $HONEYPI_ENVIRONMENT.env
  sudo find ./apps -maxdepth 1 -execdir sh -c 'mkdir -p "${HONEYPI_HOME}/${0%}"' {} \;
  echo "Running in '${HONEYPI_SCOPE}' with '${@}'"
  if [ "$HONEYPI_SCOPE" = "host" ]; then
    for arg in "${@:-$HOST_MODULES}"
    do
      . ./host/$arg.sh
    done
  elif [ "$HONEYPI_SCOPE" = "apps" ]; then
    for arg in "${@:-$APP_MODULES}"
    do
      docker-compose -f "./apps/$arg/docker-compose.yml" --env-file $HONEYPI_ENVIRONMENT.env up -d
    done
  else
    echo "Unknown scope '$1'."
  fi
  exit 0
elif [ "$1" = "remove" ]; then
  shift
  [ -f $HONEYPI_ENVIRONMENT.env ] && loadEnv $HONEYPI_ENVIRONMENT.env
  docker stop "${@}"
  docker rm -fv "${@}"
  exit 0
else
  echo "No argument(s) provided. Run -h for help."
  exit 0
fi

